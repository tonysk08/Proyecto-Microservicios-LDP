# ─────────────────────────────────────────────────────────────
# Price Service — variables de entorno
# Copia este archivo a `.env` (mismo directorio):  cp .env.example .env
# El módulo lee variables PRICE_DB_* (NO CATALOG_DB_*)
# Credenciales de BD alineadas con init/02-init-databases-users.sql
# Credenciales de RabbitMQ alineadas con docker-compose.yml
# ─────────────────────────────────────────────────────────────

# Servidor
PORT=3002
NODE_ENV=development

# Base de datos — REQUERIDO (usuario/clave creados en init/02-init-databases-users.sql)
PRICE_DB_HOST=localhost
PRICE_DB_PORT=5432
PRICE_DB_NAME=bd_prices
PRICE_DB_USER=prices_user
PRICE_DB_PASSWORD=my_prices_password
PRICE_DB_SCHEMA=pricing

# RabbitMQ — REQUERIDO para registrar el microservicio en el broker
RABBITMQ_URL=amqp://admin:admin1234@localhost:5672
# Cola de eventos (predeclarada con DLX en rabbitmq/definitions.json)
PRICE_QUEUE=pricing_queue
