# ─────────────────────────────────────────────────────────────
# Audit & Logging Service — variables de entorno
# ─────────────────────────────────────────────────────────────
NODE_ENV=development

# RabbitMQ
RABBITMQ_URL=amqp://admin:admin1234@localhost:5672
# Cola tap (# de todos los exchanges) — predeclarada en rabbitmq/definitions.json
AUDIT_QUEUE=audit_queue

# Base de datos — alineada con init/02-init-databases-users.sql
LOGS_DB_HOST=localhost
LOGS_DB_PORT=5432
LOGS_DB_NAME=bd_logs
LOGS_DB_USER=logs_user
LOGS_DB_PASSWORD=my_logs_password
LOGS_DB_SCHEMA=audit
