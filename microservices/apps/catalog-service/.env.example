# ─────────────────────────────────────────────────────────────
# Catalog Service — variables de entorno
# Copia este archivo a `.env` (mismo directorio):  cp .env.example .env
# Credenciales de BD alineadas con init/02-init-databases-users.sql
# Credenciales de RabbitMQ alineadas con docker-compose.yml
# ─────────────────────────────────────────────────────────────

# Servidor
PORT=3001
NODE_ENV=development

# Base de datos 
CATALOG_DB_HOST=localhost
CATALOG_DB_PORT=5432
CATALOG_DB_NAME=bd_catalogs
CATALOG_DB_USER=catalog_user
CATALOG_DB_PASSWORD=my_catalog_password
CATALOG_DB_SCHEMA=catalog

# RabbitMQ — REQUERIDO para registrar el microservicio en el broker
RABBITMQ_URL=amqp://admin:admin1234@localhost:5672
CATALOG_QUEUE=catalog_queue
