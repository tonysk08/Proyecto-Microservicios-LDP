# ─────────────────────────────────────────────────────────────
# Matching Service — variables de entorno
# ─────────────────────────────────────────────────────────────
NODE_ENV=development

# RabbitMQ
RABBITMQ_URL=amqp://admin:admin1234@localhost:5672
# Cola de eventos (predeclarada con DLX en rabbitmq/definitions.json)
MATCHING_QUEUE=matching_queue
# Cola RPC del catalog-service (para consultar productos candidatos)
CATALOG_QUEUE=catalog_queue

# Base de datos — alineada con init/02-init-databases-users.sql
MATCHING_DB_HOST=localhost
MATCHING_DB_PORT=5432
MATCHING_DB_NAME=bd_matching
MATCHING_DB_USER=matching_user
MATCHING_DB_PASSWORD=my_matching_password
MATCHING_DB_SCHEMA=matching

# Umbral de similitud para aceptar un match (0..1)
SIMILARITY_THRESHOLD=0.6
