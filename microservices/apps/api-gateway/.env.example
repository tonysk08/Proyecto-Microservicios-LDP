# ─────────────────────────────────────────────────────────────
# API Gateway — variables de entorno
# Copia este archivo a `.env` (mismo directorio):  cp .env.example .env
# Los valores por defecto coinciden con docker-compose.yml (admin / admin1234)
# ─────────────────────────────────────────────────────────────

# Servidor HTTP
PORT=3000
NODE_ENV=development

# RabbitMQ — REQUERIDO. Sin esta variable el gateway crashea al arrancar:
#   TypeError: Configuration key "RABBITMQ_URL" does not exist
# Formato: amqp://<user>:<pass>@<host>:<port>
RABBITMQ_URL=amqp://admin:admin1234@localhost:5672

# Colas de los microservicios (consumidas por el gateway vía ClientProxy)
CATALOG_QUEUE=catalog_queue
PRICING_QUEUE=pricing_queue
MATCHING_QUEUE=matching_queue
SCRAPING_QUEUE=scraping_queue
