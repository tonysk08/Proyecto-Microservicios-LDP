# ─────────────────────────────────────────────────────────────
# Scraper Orchestrator — variables de entorno
# ─────────────────────────────────────────────────────────────
NODE_ENV=development

# RabbitMQ — REQUERIDO
RABBITMQ_URL=amqp://admin:admin1234@localhost:5672

# Cola del orchestrator (predeclarada en rabbitmq/definitions.json)
ORCHESTRATOR_QUEUE=scraper_orchestrator_queue
SCRAPING_EXCHANGE=scraping.exchange

# Supermercados a despachar cuando la solicitud no especifica uno
SCRAPER_IDS=super99,riba-smith,el-machetazo

# Timeout (ms) para esperar scraping.completed antes de emitir scraping.failed
SCRAPE_TIMEOUT_MS=120000
