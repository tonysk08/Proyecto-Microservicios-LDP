# ─────────────────────────────────────────────────────────────
# Variables compartidas del monorepo (fallback de las apps)
# Copia a `.env`:  cp .env.example .env
# Credenciales alineadas con docker-compose.yml (admin / admin1234)
# ─────────────────────────────────────────────────────────────

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASS=admin1234
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_URL=amqp://admin:admin1234@localhost:5672
